<Window x:Class="Neftegazoborudovanie_Zuev.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:Neftegazoborudovanie_Zuev"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Настройки -->
            <RowDefinition Height="Auto"/>
            <!-- Индикаторы -->
            <RowDefinition Height="*"/>
            <!-- График -->
        </Grid.RowDefinitions>

        <!-- 1. Панель управления -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="COM Порт:" FontSize="11" Foreground="#666"/>
                <ComboBox x:Name="PortComboBox" Width="120" Height="30" VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button x:Name="BtnConnect" Content="ПОДКЛЮЧИТЬ" Click="BtnConnect_Click" 
                    Width="120" Height="30" Margin="0,15,0,0" 
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- 2. Данные -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="5" Padding="15" Margin="0,0,10,0" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="FLOAT VALUE (REG 1354)" Foreground="#888" FontSize="10"/>
                    <TextBlock x:Name="TxtFloatValue" Text="0.00" FontSize="28" FontWeight="Bold" Foreground="#222"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="5" Padding="15" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="REG 1150 STATUS" Foreground="#888" FontSize="10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Ellipse x:Name="StatusLed" Width="15" Height="15" Fill="DarkGray" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtStatus" Text="IDLE" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 3. График -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1">
            <ScottPlot:WpfPlot Name="WpfPlot1" />
        </Border>
    </Grid>
</Window>
